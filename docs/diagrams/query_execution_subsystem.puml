@startuml
title Подсистема выполнения запросов (поиск)

actor "Клиент системы" as Client
participant "FastAPI\nPOST /v1/search" as API
participant "SearchService\nsearch" as Service
participant "EmbeddingService\nembed_text" as Emb
participant "OpenSearchAdapter\nlexical_search / vector_search" as OS
participant "Neo4jAdapter\nfetch_graph_context" as Neo
database "OpenSearch" as OSDb
database "Neo4j" as NeoDb

Client -> API: POST /v1/search {query, limit, lexical_weight?, vector_weight?}
API -> Service: search(query, limit, lexical_weight, vector_weight)

Service -> Service: resolve_weights()
Service -> Emb: embed_text(query)
alt query embedding failed
  Service --> API: []
  API --> Client: SearchResponse(items=[])
  return
end

par lexical channel
  Service -> OS: lexical_search(query, lexical_limit)
  OS -> OSDb: POST /{index}/_search/template (lexical)
  OSDb --> OS: lexical hits
  OS --> Service: lexical_results
else vector channel
  Service -> OS: vector_search(query_vector, vector_limit)
  OS -> OSDb: POST /{index}/_search/template (vector)
  OSDb --> OS: vector hits
  OS --> Service: vector_results
end

Service -> Service: normalize lexical scores (min-max)
Service -> Service: normalize vector scores (min-max)
Service -> Service: merge weighted results\n(build debug lexical/vector/combined)
Service -> Service: filter lexical-only with vector_raw=0\nwhen vector_weight>0
Service -> Service: sort by combined score desc
Service -> Service: take top limit

Service -> Neo: fetch_graph_context(item_ids, limits)
Neo -> NeoDb: execute rendered graph_context Cypher template
NeoDb --> Neo: context rows (or error)
Neo --> Service: graph_context_map (may be empty)
Service -> Service: attach payload.graph to matched items\n(if context exists)
Service --> API: enriched_items
API --> Client: SearchResponse(items)

@enduml
