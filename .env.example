APP_NAME=graphrag-search-api
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
REQUEST_ID_HEADER=X-Request-ID
API_V1_PREFIX=/v1
DOMAIN_NAME=movies
DOMAINS_ROOT=app/domains
METRICS_ENABLED=true
METRICS_PATH=/metrics
API_TIMEOUT_SECONDS=5
OPENSEARCH_TIMEOUT_SECONDS=60
EMBEDDING_TIMEOUT_SECONDS=120
RETRY_ATTEMPTS=3
RETRY_WAIT_SECONDS=0.5
OPENSEARCH_BASE_URL=http://localhost:9200
OPENSEARCH_INDEX=movies
OPENSEARCH_TITLE_FIELD=title
OPENSEARCH_CONTENT_FIELD=content
OPENSEARCH_METADATA_FIELD=metadata
OPENSEARCH_VECTOR_FIELD=embedding
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_PRELOAD_ON_STARTUP=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_ENDPOINT=/api/embed
OLLAMA_EMBEDDING_LEGACY_ENDPOINT=/api/embeddings
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:4b-instruct
LLM_BASE_URL=http://localhost:11434
LLM_OLLAMA_GENERATE_ENDPOINT=/api/generate
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0.2
LLM_PRELOAD_ON_STARTUP=false
LEXICAL_SEARCH_WEIGHT=0.6
VECTOR_SEARCH_WEIGHT=0.4
LEXICAL_CANDIDATE_SIZE=40
VECTOR_CANDIDATE_SIZE=60
GRAPH_CONTEXT_PERSON_LIMIT=10
GRAPH_RELATED_MOVIES_LIMIT=10
GRAPH_RELATED_SHARED_PEOPLE_LIMIT=10
GRAPH_INGEST_BATCH_SIZE=25
BULK_INDEX_BATCH_SIZE=25
