APP_NAME=graphrag-search-api
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
REQUEST_ID_HEADER=X-Request-ID
API_V1_PREFIX=/v1
DOMAIN_NAME=movies
DOMAINS_ROOT=app/domains
API_TIMEOUT_SECONDS=5
RETRY_ATTEMPTS=3
RETRY_WAIT_SECONDS=0.5
OPENSEARCH_BASE_URL=http://localhost:9200
OPENSEARCH_INDEX=movies
OPENSEARCH_TITLE_FIELD=title
OPENSEARCH_CONTENT_FIELD=content
OPENSEARCH_METADATA_FIELD=metadata
OPENSEARCH_VECTOR_FIELD=embedding
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_PRELOAD_ON_STARTUP=true
LEXICAL_SEARCH_WEIGHT=0.6
VECTOR_SEARCH_WEIGHT=0.4
LEXICAL_CANDIDATE_SIZE=40
VECTOR_CANDIDATE_SIZE=60
BULK_INDEX_BATCH_SIZE=100
